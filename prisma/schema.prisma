generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  plan          String    @default("free")
  usageCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  chats         Chat[]
}

model Chat {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prompt    String
  response  String
  createdAt DateTime @default(now())
}